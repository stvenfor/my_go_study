# 环境变量模板，可复制为 .env 供 docker-compose 使用。

APP_ENV=dev
SERVER_PORT=8080
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_DBNAME=my_go_study
REDIS_ADDR=localhost:6379
JWT_SECRET=change-me-in-production

# 与 Flutter my_ai_project 共用同一 Supabase Project
SUPABASE_URL=https://uqznnzkugvhsrlcudrbj.supabase.co
SUPABASE_ANON_KEY=your-publishable-or-anon-key
# 可选：service_role 仅放 .env.local，勿写入本文件（GitHub 推送保护会拦截 sb_secret_）
SUPABASE_SERVICE_ROLE_KEY=
